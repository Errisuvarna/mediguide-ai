# Root-level example env (mirrors backend/.env.example and frontend/.env.example)
# Copy the relevant one into backend/.env and frontend/.env respectively.

# --- Backend ---
SECRET_KEY=change-this-to-a-long-random-secret-in-production
DATABASE_URL=sqlite:///./mediguide.db
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash
EMBEDDING_MODEL=all-MiniLM-L6-v2
FRONTEND_ORIGIN=http://localhost:5173

# --- Frontend ---
VITE_BACKEND_URL=http://localhost:8000
